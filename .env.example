# MikroTik Management Dashboard - Configuración de Entorno
# 
# Copia este archivo a .env y configura con tus valores
# cp .env.example .env
#
# Las variables marcadas con [REQUERIDO] deben completarse obligatoriamente
# Las variables marcadas con [OPCIONAL] pueden omitirse y usarán valores por defecto

# ============================================================================
# CONFIGURACIÓN DE MIKROTIK [REQUERIDO]
# ============================================================================

# IP o nombre de host del dispositivo MikroTik
# Ejemplo: 192.168.1.1, mikrotik.local, router.example.com
MK_IP=192.168.191.16

# Puerto SSH para API de MikroTik (usualmente 22, a veces 2222)
# Por defecto: 22
MK_PORT=22

# Usuario API de MikroTik
# IMPORTANTE: El usuario debe tener permisos de API en MikroTik
# Winbox -> System -> Users -> [usuario] -> API: ON
MK_USER=user

# Contraseña del usuario API
# IMPORTANTE: Protege este valor en producción
MK_PASS=user1

# ============================================================================
# CONFIGURACIÓN DE LA APLICACIÓN [OPCIONAL]
# ============================================================================

# Modo de ejecución: none, demo, production
# - none: conecta a MikroTik real (requiere MK_IP, MK_USER, MK_PASS)
# - demo: usa datos simulados sin necesidad de MikroTik
# - production: con optimizaciones de rendimiento
# Por defecto: none
APP_MODE=none

# Intervalo de actualización de tráfico en minutos (legacy)
INTERVALO_MINUTOS=5

# Nivel de logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Por defecto: INFO
LOG_LEVEL=INFO

# Archivo de logs (opcional)
# Por defecto: logs/app.log
LOG_FILE=logs/app.log

# ============================================================================
# CONFIGURACIÓN DE BASE DE DATOS [OPCIONAL]
# ============================================================================

# URL de conexión a base de datos
# SQLite: sqlite:///./traffic_counter.db
# PostgreSQL: postgresql://usuario:contraseña@localhost/mikrotik_db
DATABASE_URL=sqlite:///./traffic_counter.db

# ============================================================================
# CONFIGURACIÓN WEB [OPCIONAL]
# ============================================================================

# Host donde escucha la aplicación
# Por defecto: 0.0.0.0 (accesible desde cualquier interfaz)
# En producción, considera usar: localhost
SERVER_HOST=0.0.0.0

# Puerto de la aplicación
# Por defecto: 8000
SERVER_PORT=8000

# URL base de la aplicación (para links absolutos)
# Por defecto: http://localhost:8000
# En producción: https://tudominio.com
APP_URL=http://localhost:8000

# Secret key para sesiones y CSRF
# Por defecto: se genera automáticamente
# En producción, establece una frase segura
SECRET_KEY=tu_clave_segura_cambiar_en_produccion

# ============================================================================
# CONFIGURACIÓN DE SEGURIDAD [RECOMENDADO]
# ============================================================================

# Habilitar HTTPS
# Por defecto: false
SECURE=false

# Certificado SSL (ruta a archivo .pem si SECURE=true)
# CERT_FILE=/etc/ssl/certs/cert.pem
# CERT_KEY=/etc/ssl/private/key.pem

# Dominios permitidos (CORS)
# Por defecto: localhost
# En producción: tudominio.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================================
# CONFIGURACIÓN DE MONITOREO [OPCIONAL]
# ============================================================================

# Intervalo de actualización de tráfico en segundos
# Por defecto: 60
TRAFFIC_UPDATE_INTERVAL=60

# Días de historial de tráfico a mantener
# Por defecto: 90
TRAFFIC_HISTORY_DAYS=90

# ============================================================================
# CONFIGURACIÓN DE INTERFAZ [OPCIONAL]
# ============================================================================

# Título de la aplicación en navegador
# Por defecto: MikroTik Management Dashboard
APP_TITLE=MikroTik Management Dashboard

# Intervalo de actualización de gráficos en milisegundos
# Por defecto: 5000 (5 segundos)
CHART_UPDATE_INTERVAL=5000

# Número máximo de clientes a mostrar en tabla
# Por defecto: 100
MAX_CLIENTS_DISPLAY=100

# ============================================================================
# NOTAS DE SEGURIDAD
# ============================================================================

# IMPORTANTE:
# 1. NUNCA commits .env a GitHub (ya está en .gitignore)
# 2. En producción, usa variables de entorno del sistema:
#    export MK_PASS="contraseña"
#    docker run -e MK_PASS="$MK_PASS" ...
# 3. Cambia valores por defecto en producción
# 4. Usa contraseñas fuertes (>12 caracteres)
# 5. Limita acceso de red con firewall
# 6. Actualiza credenciales regularmente
# 7. Monitorea logs para accesos sospechosos
# 8. Usa HTTPS en producción (ver DEPLOYMENT.md)

# ============================================================================
# REFERENCIAS
# ============================================================================

